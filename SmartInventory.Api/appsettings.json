{
  "ConnectionStrings": {
    "SmartInventoryDb": "Server=YOUR_SERVER;Database=YOUR_DATABASE;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True"
  },

  "Redis": {
    "ConnectionString": "localhost:6379"
  },

  "Jwt": {
    "Issuer": "SmartInventory",
    "Audience": "SmartInventoryUsers",
    "Key": "YOUR_SUPER_SECRET_JWT_KEY",
    "ExpiresInMinutes": 60
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}